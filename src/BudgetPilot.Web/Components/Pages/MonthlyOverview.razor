@page "/monatsuebersicht"
@rendermode InteractiveServer
@inject IBudgetProjectionService Projections

<PageTitle>Monatsübersicht · BudgetPilot</PageTitle>

<header class="page-header">
    <div>
        <p class="eyebrow">Monatsplanung</p>
        <h1>Monatsübersicht</h1>
    </div>
    <div class="header-actions">
        <button class="button secondary" @onclick="PreviousMonth">‹</button>
        <span class="date-chip">@CurrentMonth.ToString("MMMM yyyy", culture)</span>
        <button class="button secondary" @onclick="NextMonth">›</button>
    </div>
</header>

<div class="segmented">
    <button class="@(ViewMode == BudgetViewMode.Budget ? "active" : null)" @onclick="() => SetView(BudgetViewMode.Budget)">Budget-Sicht</button>
    <button class="@(ViewMode == BudgetViewMode.Cashflow ? "active" : null)" @onclick="() => SetView(BudgetViewMode.Cashflow)">Cashflow-Sicht</button>
</div>
<p class="hint">@ViewHint</p>

@if (projection is null)
{
    <p>Lade Monatsübersicht ...</p>
}
else
{
    <section class="kpi-grid">
        <article class="kpi-card income"><span>Einnahmen</span><strong>@Money(projection.TotalIncome)</strong></article>
        <article class="kpi-card expense"><span>Ausgaben</span><strong>@Money(projection.TotalExpense)</strong></article>
        <article class="kpi-card balance @(projection.Balance >= 0 ? "positive" : "negative")"><span>Saldo</span><strong>@Money(projection.Balance)</strong></article>
    </section>

    <section class="panel section-income">
        <header class="panel-header">
            <span class="pill income">Einnahmen</span>
            <strong class="numeric text-positive">@Money(projection.Lines.Where(l => l.Type == BudgetItemType.Income).Sum(l => l.ProjectedMonthlyAmount))</strong>
        </header>
        <div class="line-list">
            @foreach (var line in projection.Lines.Where(l => l.Type == BudgetItemType.Income))
            {
                <div class="budget-line @(line.ProjectedMonthlyAmount == 0 ? "muted-line" : null)">
                    <div>
                        <strong>@line.BudgetItemName</strong>
                        <span>@UiText.FrequencyLabel(line.Frequency)@(string.IsNullOrWhiteSpace(line.Note) ? "" : $" · {line.Note}")</span>
                    </div>
                    @if (LineTag(line) is { Length: > 0 } incTag)
                    {
                        <span class="pill neutral">@incTag</span>
                    }
                    <strong class="numeric text-positive">@Money(line.ProjectedMonthlyAmount)</strong>
                </div>
            }
        </div>
    </section>

    @foreach (var group in projection.Lines.Where(l => l.Type == BudgetItemType.Expense).GroupBy(l => l.CategoryName).OrderBy(g => g.Key))
    {
        <section class="panel section-expense">
            <header class="panel-header">
                <span class="pill expense">@group.Key</span>
                <strong class="numeric text-negative">@Money(group.Sum(l => l.ProjectedMonthlyAmount))</strong>
            </header>
            <div class="line-list">
                @foreach (var line in group.OrderBy(l => l.BudgetItemName))
                {
                    <div class="budget-line @(line.ProjectedMonthlyAmount == 0 ? "muted-line" : null)">
                        <div>
                            <strong>@line.BudgetItemName</strong>
                            <span>@UiText.FrequencyLabel(line.Frequency) · Basis @Money(line.Amount)</span>
                        </div>
                        @if (LineTag(line) is { Length: > 0 } expTag)
                        {
                            <span class="pill neutral">@expTag</span>
                        }
                        <strong class="numeric @(line.ProjectedMonthlyAmount == 0 ? null : "text-negative")">@Money(line.ProjectedMonthlyAmount)</strong>
                    </div>
                }
            </div>
        </section>
    }
}

@code {
    private readonly CultureInfo culture = CultureInfo.GetCultureInfo("de-DE");
    private DateOnly CurrentMonth { get; set; } = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private BudgetViewMode ViewMode { get; set; } = BudgetViewMode.Budget;
    private MonthlyBudgetProjectionDto? projection;
    private string ViewHint => ViewMode == BudgetViewMode.Budget
        ? "Budget-Sicht verteilt quartalsweise und jährliche Zahlungen gleichmäßig auf Monate."
        : "Cashflow-Sicht zeigt Zahlungen nur im tatsächlichen Fälligkeitsmonat.";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        projection = await Projections.GetMonthlyProjectionAsync(CurrentMonth.Year, CurrentMonth.Month, ViewMode);
    }

    private async Task PreviousMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        await LoadAsync();
    }

    private async Task NextMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(1);
        await LoadAsync();
    }

    private async Task SetView(BudgetViewMode mode)
    {
        ViewMode = mode;
        await LoadAsync();
    }

    // Tag nur für „lumpy" Kosten (Quartal/Jahr/Einmalig); für reine Monatsposten kein Tag (wie in der Vorlage).
    private string LineTag(BudgetProjectionLine line)
    {
        if (line.Frequency == BudgetFrequency.Monthly)
        {
            return string.Empty;
        }

        if (ViewMode == BudgetViewMode.Budget)
        {
            return "anteilig";
        }

        return line.IsDue ? "fällig" : "nicht fällig";
    }

    private string Money(decimal value) => value.ToString("C", culture);
}
