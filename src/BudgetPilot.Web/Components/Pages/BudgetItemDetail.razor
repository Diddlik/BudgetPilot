@page "/budgetpositionen/{Id:guid}"
@rendermode InteractiveServer
@inject IBudgetItemService Items
@inject IBudgetProjectionService Projections
@inject NavigationManager Nav

<PageTitle>Position · BudgetPilot</PageTitle>

@if (item is null)
{
    <p>Lade Position ...</p>
}
else
{
    <header class="page-header">
        <div>
            <p class="eyebrow">@item.CategoryName</p>
            <h1>@item.Name</h1>
            <div class="pill-row">
                <span class="pill @(item.Type == BudgetItemType.Income ? "income" : "expense")">@UiText.TypeLabel(item.Type)</span>
                <span class="pill @(item.IsActive ? "success" : "muted")">@(item.IsActive ? "Aktiv" : "Inaktiv")</span>
            </div>
        </div>
        <div class="header-actions">
            <button class="button secondary" @onclick="OpenEdit">Bearbeiten</button>
            <button class="button secondary" @onclick="ToggleActiveAsync">@(item.IsActive ? "Deaktivieren" : "Reaktivieren")</button>
            <button class="button danger" @onclick="() => confirmDelete = true">Löschen</button>
        </div>
    </header>

    <section class="panel action-panel">
        <div>
            <h2>Betrag ab einem Datum ändern</h2>
            <p class="hint">Neue Version ab Datum ist der sichere Standard. Historische Monate bleiben unverändert.</p>
        </div>
        <div class="radio-row" aria-label="Versionierungsmodus">
            <label><input type="radio" checked /> Neue Version ab Datum</label>
            <label class="muted"><input type="radio" disabled /> rückwirkend</label>
        </div>
        <button class="button primary" @onclick="OpenVersion">Neue Version anlegen</button>
    </section>

    <section class="panel">
        <header class="panel-header">
            <h2>Versionshistorie</h2>
            <span>neueste oben</span>
        </header>
        <div class="timeline">
            @foreach (var version in item.Versions.OrderByDescending(v => v.ValidFrom))
            {
                <article class="timeline-entry">
                    <div class="timeline-dot"></div>
                    <div class="timeline-card">
                        <header>
                            <strong class="numeric">@Money(version.Amount)</strong>
                            <div class="timeline-actions">
                                <span class="pill @(version.IsCurrent ? "success" : "neutral")">@(version.IsCurrent ? "Aktuell" : "Historisch")</span>
                                <button class="button secondary tiny" @onclick="() => OpenVersionEdit(version.Id)">Korrigieren</button>
                            </div>
                        </header>
                        <dl>
                            <div><dt>Frequenz</dt><dd>@UiText.FrequencyLabel(version.Frequency)</dd></div>
                            <div><dt>Gültig ab</dt><dd>@version.ValidFrom.ToString("dd.MM.yyyy", culture)</dd></div>
                            <div><dt>Gültig bis</dt><dd>@(version.ValidTo?.ToString("dd.MM.yyyy", culture) ?? "offen")</dd></div>
                            <div><dt>Zahlung</dt><dd>@PaymentText(version)</dd></div>
                        </dl>
                        @if (!string.IsNullOrWhiteSpace(version.Note))
                        {
                            <p class="hint">@version.Note</p>
                        }
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="panel">
        <header class="panel-header">
            <h2>Zahlungsplan</h2>
            <span>Cashflow · @ScheduleFromYear–@ScheduleToYear</span>
        </header>
        @if (schedule is null)
        {
            <p class="hint">Lade Zahlungsplan ...</p>
        }
        else if (schedule.Count == 0)
        {
            <p class="hint">Keine fälligen Zahlungen in diesem Zeitraum.</p>
        }
        else
        {
            <p class="hint compact">@schedule.Count Zahlung(en) von @ScheduleFromYear bis @ScheduleToYear.</p>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr><th>Jahr</th><th>Fällige Monate</th><th class="numeric">Betrag/Zahlung</th><th class="numeric">Jahressumme</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var group in schedule.GroupBy(e => e.Year).OrderBy(g => g.Key))
                        {
                            <tr>
                                <td>@group.Key</td>
                                <td>@string.Join(", ", group.OrderBy(e => e.Month).Select(e => culture.DateTimeFormat.GetAbbreviatedMonthName(e.Month)))</td>
                                <td class="numeric">@Money(group.First().Amount)</td>
                                <td class="numeric">@Money(group.Sum(e => e.Amount))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

@if (formMode is not null && item is not null)
{
    <BudgetItemForm Mode="@formMode" Item="@item" VersionId="@editVersionId" OnSaved="SavedAsync" OnCancel="CloseForm" />
}

@if (confirmDelete && item is not null)
{
    <div class="modal-backdrop">
        <section class="confirm-box">
            <h2>Position löschen?</h2>
            <p>@item.Name wird mit allen Versionen entfernt.</p>
            <div class="sheet-actions">
                <button class="button secondary" @onclick="() => confirmDelete = false">Abbrechen</button>
                <button class="button danger" @onclick="DeleteAsync">Löschen</button>
            </div>
        </section>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private readonly CultureInfo culture = CultureInfo.GetCultureInfo("de-DE");
    private BudgetItemDto? item;
    private string? formMode;
    private Guid? editVersionId;
    private bool confirmDelete;
    private IReadOnlyList<PaymentScheduleEntry>? schedule;
    private int ScheduleFromYear { get; set; }
    private int ScheduleToYear { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        item = await Items.GetByIdAsync(Id);
        await LoadScheduleAsync();
    }

    private async Task LoadScheduleAsync()
    {
        schedule = null;
        if (item is null || item.Versions.Count == 0)
        {
            return;
        }

        // Von der frühesten Version bis fünf Jahre in die Zukunft.
        ScheduleFromYear = item.Versions.Min(v => v.ValidFrom).Year;
        ScheduleToYear = Math.Max(DateTime.Today.Year + 5, ScheduleFromYear);
        schedule = await Projections.GetPaymentScheduleAsync(item.Id, ScheduleFromYear, ScheduleToYear);
    }

    private async Task ToggleActiveAsync()
    {
        if (item is null)
        {
            return;
        }

        if (item.IsActive)
        {
            await Items.DeactivateAsync(item.Id);
        }
        else
        {
            await Items.ReactivateAsync(item.Id);
        }

        item = await Items.GetByIdAsync(item.Id);
        await LoadScheduleAsync();
    }

    private void OpenEdit()
    {
        editVersionId = null;
        formMode = "Edit";
    }

    private void OpenVersion()
    {
        editVersionId = null;
        formMode = "Version";
    }

    private void OpenVersionEdit(Guid versionId)
    {
        editVersionId = versionId;
        formMode = "EditVersion";
    }

    private async Task SavedAsync(BudgetItemDto? saved)
    {
        formMode = null;
        editVersionId = null;
        item = saved ?? await Items.GetByIdAsync(Id);
        await LoadScheduleAsync();
    }

    private Task CloseForm()
    {
        formMode = null;
        editVersionId = null;
        return Task.CompletedTask;
    }

    private async Task DeleteAsync()
    {
        if (item is null)
        {
            return;
        }

        await Items.DeleteAsync(item.Id);
        Nav.NavigateTo("/budgetpositionen");
    }

    private string PaymentText(BudgetItemVersionDto version)
    {
        if (version.Frequency == BudgetFrequency.Monthly)
        {
            return "jeden Monat";
        }

        if (version.PaymentMonth is int month)
        {
            return culture.DateTimeFormat.GetMonthName(month);
        }

        return "aus Gültig ab";
    }

    private string Money(decimal value) => value.ToString("C", culture);
}
