<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="BudgetPilot.Web.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="apple-touch-icon" href="icons/icon-192.png" />
    <meta name="theme-color" content="#166534" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="BudgetPilot" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Mobiles "Mehr"-Menü (natives <details>): bei Klick außerhalb oder auf
        // einen Eintrag schließen. Document-Listener überlebt Enhanced Navigation.
        document.addEventListener('click', function (e) {
            var open = document.querySelector('.more-menu[open]');
            if (!open) return;
            if (e.target.closest('.more-backdrop') ||
                e.target.closest('.more-item') ||
                !e.target.closest('.more-menu')) {
                open.removeAttribute('open');
            }
        });
    </script>
</body>

</html>
