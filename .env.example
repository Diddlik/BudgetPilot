# Copy to ".env" and fill in. Never commit the real .env (it is gitignored).

# Single private login account, seeded on first start.
# Password must be >= 8 chars with upper/lower/digit/symbol.
BP_AUTH_EMAIL=you@example.com
BP_AUTH_PASSWORD=ChangeMe!2026

# Host port the container publishes (Nginx Proxy Manager forwards here). Default 8080.
APP_PORT=8080

# Auto-update deploy (docker-compose.deploy.yml): which prebuilt image to pull.
# Defaults to the latest from GHCR; pin a sha-<commit> tag here to roll back.
BP_IMAGE=ghcr.io/diddlik/budgetpilot:latest

# Only needed for the Caddy variant (docker-compose.prod.yml); ignored with NPM.
DOMAIN=budget.example.com
